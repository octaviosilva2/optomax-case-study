# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
# log do next dev redirecionado (gerado localmente)
dev.log

# env files (can opt-in for committing if needed)
.env*
# ...exceto o template versionado (sem valores reais — só as chaves e o propósito).
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local env files
.env.local
.env.*.local

# Claude Code / dev tooling local (configs e skills por máquina)
.claude/
.agents/

# Prompts internos de desenvolvimento (rascunhos de tarefas)
prompts/

# Prints gerados pelo script scripts/screenshot-all.ts
screenshots/

# Playwright — auth state e relatórios
tests/visual/.auth/
playwright-report/
test-results/

# Codemod logs (gerados localmente quando rodar scripts/codemod-colors.ts)
codemod-dryrun*.log

# Lighthouse CI cache
.lighthouseci/
