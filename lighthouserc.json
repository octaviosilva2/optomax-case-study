{
  "$schema": "https://raw.githubusercontent.com/nicholascelestin/lighthouse-ci/master/docs/configuration.schema.json",
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3000/login",
        "http://localhost:3000/comece",
        "http://localhost:3000/termos",
        "http://localhost:3000/privacidade",
        "http://localhost:3000/contato"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "provided",
        "chromeFlags": "--headless --no-sandbox --disable-gpu"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:accessibility": ["warn", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./tests/a11y/lighthouse"
    }
  }
}
