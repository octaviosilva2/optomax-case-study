# ==============================================================================
# OptoMax — template de variáveis de ambiente
# ==============================================================================
# Copie para `.env.local` e preencha com os valores reais (NUNCA commitar valores).
# Todas as chaves abaixo são efetivamente lidas pelo código (grep `process.env.`).
# `NEXT_PUBLIC_*` é exposto ao browser — não colocar segredo nessas.
# Em produção, os valores vivem nas env vars da Vercel (Production/Preview/Development).
# ==============================================================================

# ── Supabase ──────────────────────────────────────────────────────────────────
# Projeto Supabase (Postgres + Auth + Storage + RLS). URL e ANON são públicas;
# a SERVICE_ROLE é segredo de servidor (bypassa RLS) — só usada em src/app/api/.
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Painel /admin ─────────────────────────────────────────────────────────────
# Autenticação do back-office (sem usuário no Supabase Auth): par (email, senha)
# global. ADMIN_PASSWORD também é a CHAVE do HMAC que assina o cookie de sessão —
# rotacioná-la derruba todas as sessões admin. Mínimo 8 caracteres.
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Segundo fator (TOTP / app autenticador). Segredo base32 gerado uma vez e cadastrado
# no app (Google Authenticator/Authy/1Password). EXIGIDO em produção: sem ele o login
# admin fica BLOQUEADO (falha fechada). Em dev, se ausente, o 2FA é desligado (só warn).
# NUNCA commitar o valor real.
ADMIN_TOTP_SECRET=

# ── App / suporte ─────────────────────────────────────────────────────────────
# URL canônica do app — usada em emailRedirectTo / redirectTo (evita capturar www).
NEXT_PUBLIC_APP_URL=https://optomax.com.br
# Versão exibida no menu do avatar (fallback 'v0.1' se ausente).
NEXT_PUBLIC_APP_VERSION=
# WhatsApp de suporte, formato wa.me (só dígitos — sem +, espaços ou hifens).
# Usado pelo botão "Reportar problema", banner de trial expirado e página de contato.
NEXT_PUBLIC_SUPPORT_WHATSAPP=5548998079707

# ── Modo manutenção ───────────────────────────────────────────────────────────
# BLOQUEIO real ("fecha a loja"): quando "true", o gate no (app)/layout.tsx
# barra todos os usuários, exceto orgs plan='admin' e e-mails do bypass abaixo.
# Sem prefixo NEXT_PUBLIC porque é lido só em Server Components. Reversível pela
# Vercel (troca a env + redeploy), sem mudança de código.
MAINTENANCE_MODE=false
# Lista CSV de e-mails que passam pelo bloqueio (rede de segurança p/ contas de teste).
MAINTENANCE_BYPASS_EMAILS=
# BANNER visual (distinto do bloqueio): quando "true", mostra um aviso amarelo no
# topo de todas as páginas. Não impede o uso — só comunica.
NEXT_PUBLIC_MAINTENANCE=false
# Texto custom — reusado pelo banner E pela tela de bloqueio. Vazio = mensagem padrão.
NEXT_PUBLIC_MAINTENANCE_MESSAGE=

# ── Paywall / Cron ────────────────────────────────────────────────────────────
# Segredo do Vercel Cron: injetado como header Authorization nas chamadas a
# /api/cron/*. A rota rejeita (401) sem ele — falha fechada. NUNCA commitar.
CRON_SECRET=
# Liga o CORTE do paywall (trial vencido → 'expired'). Ausente/false = o cron roda
# mas NÃO corta ninguém. Setar "true" só na data de corte combinada.
PAYWALL_ENABLED=false

# ── Pagamentos (ASAAS) ────────────────────────────────────────────────────────
# Gateway ASAAS: Pix + cartão recorrente. BASE_URL alterna sandbox/produção;
# usa API_KEY_SANDBOX quando aponta pro sandbox, API_KEY na produção.
ASAAS_BASE_URL=
ASAAS_API_KEY=
ASAAS_API_KEY_SANDBOX=
# Token que autentica o webhook do ASAAS em /api/webhooks/asaas (falha fechada).
ASAAS_WEBHOOK_TOKEN=
# Flag do cartão tokenizado. Pix funciona independente disto. Só ativa a UI de
# cartão com "true" E habilitação ASAAS aprovada em produção.
PAYMENTS_CREDIT_CARD_ENABLED=false

# ── Observabilidade (Sentry) ──────────────────────────────────────────────────
# DSN público do Sentry (exposto ao client). Sem ele, o Sentry não inicializa.
NEXT_PUBLIC_SENTRY_DSN=
# Token de build (só CI/Vercel) para subir source maps. Sem ele o build NÃO falha —
# apenas as stack traces sobem minificadas. Não é necessário em dev local.
SENTRY_AUTH_TOKEN=
